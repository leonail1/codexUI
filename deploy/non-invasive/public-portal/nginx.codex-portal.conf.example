map $http_upgrade $connection_upgrade {
    default upgrade;
    '' close;
}

server {
    listen 80 default_server;
    listen [::]:80 default_server;
    server_name _;

    location /.well-known/acme-challenge/ {
        root /var/www/certbot;
        try_files $uri =404;
    }

    location / {
        return 301 https://$host$request_uri;
    }
}

server {
    listen 443 ssl http2 default_server;
    listen [::]:443 ssl http2 default_server;
    server_name _;

    ssl_certificate /etc/letsencrypt/live/codex-ip-106-55-9-238/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/codex-ip-106-55-9-238/privkey.pem;
    ssl_protocols TLSv1.2 TLSv1.3;
    ssl_session_timeout 1d;
    ssl_session_cache shared:SSL:10m;
    ssl_prefer_server_ciphers off;

    location /auth/ {
        proxy_pass http://127.0.0.1:18081/;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Codex-Target-Label Portal;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header X-Original-URI $request_uri;
    }

    location = /_auth_internal_check {
        internal;
        proxy_pass http://127.0.0.1:18081/check;
        proxy_pass_request_body off;
        proxy_set_header Content-Length "";
        proxy_set_header Host $host;
        proxy_set_header Cookie $http_cookie;
        proxy_set_header X-Original-URI $request_uri;
    }

    location = / {
        auth_request /_auth_internal_check;
        error_page 401 = @portal_login_redirect;
        alias /var/www/codex-selector/index.html;
        default_type text/html;
        add_header Cache-Control "no-store";
    }

    location = /servers {
        auth_request /_auth_internal_check;
        error_page 401 = @portal_login_redirect;
        alias /var/www/codex-selector/index.html;
        default_type text/html;
        add_header Cache-Control "no-store";
    }

    location = /sw.js {
        alias /var/www/codex-selector/sw.js;
        default_type application/javascript;
        add_header Cache-Control "no-store";
    }

    location @portal_login_redirect {
        return 302 /auth/login?next=/servers;
    }
}

server {
    listen 24431 ssl http2;
    listen [::]:24431 ssl http2;
    server_name _;

    ssl_certificate /etc/letsencrypt/live/codex-ip-106-55-9-238/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/codex-ip-106-55-9-238/privkey.pem;
    ssl_protocols TLSv1.2 TLSv1.3;
    ssl_session_timeout 1d;
    ssl_session_cache shared:SSL:10m;
    ssl_prefer_server_ciphers off;

    include /etc/nginx/snippets/codex-backend-common.conf;
    set $codex_backend_port 22340;
    set $codex_target_label a100;
}

server {
    listen 24432 ssl http2;
    listen [::]:24432 ssl http2;
    server_name _;

    ssl_certificate /etc/letsencrypt/live/codex-ip-106-55-9-238/fullchain.pem;
