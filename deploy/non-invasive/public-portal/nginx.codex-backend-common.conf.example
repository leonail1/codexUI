location /auth/ {
    proxy_pass http://127.0.0.1:18081/;
    proxy_http_version 1.1;
    proxy_set_header Host $host;
    proxy_set_header X-Codex-Target-Label $codex_target_label;
    proxy_set_header X-Real-IP $remote_addr;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto $scheme;
    proxy_set_header X-Original-URI $request_uri;
}

location = /_auth_internal_check {
    internal;
    proxy_pass http://127.0.0.1:18081/check;
    proxy_pass_request_body off;
    proxy_set_header Content-Length "";
    proxy_set_header Host $host;
    proxy_set_header Cookie $http_cookie;
    proxy_set_header X-Original-URI $request_uri;
}

location = /sw.js {
    alias /var/www/codex-selector/sw.js;
    default_type application/javascript;
    add_header Cache-Control "no-store";
}

location /codex-api/ {
    auth_request /_auth_internal_check;
    error_page 401 = @api_unauthorized;

    proxy_pass http://127.0.0.1:$codex_backend_port;
    add_header X-Codex-Target $codex_target_label always;
    proxy_http_version 1.1;
    proxy_set_header Host $host;
    proxy_set_header X-Real-IP $remote_addr;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto $scheme;
    proxy_set_header Upgrade $http_upgrade;
    proxy_set_header Connection $connection_upgrade;
    proxy_read_timeout 3600;
    proxy_send_timeout 3600;
}

location /codex-local- {
    auth_request /_auth_internal_check;
    error_page 401 = @api_unauthorized;

    proxy_pass http://127.0.0.1:$codex_backend_port;
    add_header X-Codex-Target $codex_target_label always;
    proxy_http_version 1.1;
    proxy_set_header Host $host;
    proxy_set_header X-Real-IP $remote_addr;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto $scheme;
    proxy_set_header Upgrade $http_upgrade;
    proxy_set_header Connection $connection_upgrade;
    proxy_read_timeout 3600;
    proxy_send_timeout 3600;
}

location / {
    auth_request /_auth_internal_check;
    error_page 401 = @login_redirect;

    proxy_pass http://127.0.0.1:$codex_backend_port;
    add_header X-Codex-Target $codex_target_label always;
    proxy_http_version 1.1;
    proxy_set_header Host $host;
    proxy_set_header X-Real-IP $remote_addr;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto $scheme;
    proxy_set_header Upgrade $http_upgrade;
    proxy_set_header Connection $connection_upgrade;
    proxy_read_timeout 3600;
    proxy_send_timeout 3600;
}

location @login_redirect {
    return 302 /auth/login?next=$request_uri;
}

location @api_unauthorized {
    return 401;
}
