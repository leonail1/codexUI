    ssl_protocols TLSv1.2 TLSv1.3;
    ssl_session_timeout 1d;
    ssl_session_cache shared:SSL:10m;
    ssl_prefer_server_ciphers off;

    include /etc/nginx/snippets/codex-backend-common.conf;
    set $codex_backend_port 22339;
    set $codex_target_label v100;
}

server {
    listen 24433 ssl http2;
    listen [::]:24433 ssl http2;
    server_name _;

    ssl_certificate /etc/letsencrypt/live/codex-ip-106-55-9-238/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/codex-ip-106-55-9-238/privkey.pem;
    ssl_protocols TLSv1.2 TLSv1.3;
    ssl_session_timeout 1d;
    ssl_session_cache shared:SSL:10m;
    ssl_prefer_server_ciphers off;

    include /etc/nginx/snippets/codex-backend-common.conf;
    set $codex_backend_port 22341;
    set $codex_target_label node6;
}
